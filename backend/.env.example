APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
API_DOCS_ENABLED=false
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
APP_TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=morata_fms
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Production custom-domain cookie auth example:
# APP_URL=https://api.fmmcbs.com
# FRONTEND_URL=https://app.fmmcbs.com
# API_DOCS_ENABLED=false
# TURNSTILE_ENABLED=true
# TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
# APP_TRUSTED_PROXIES=203.0.113.10,198.51.100.0/24
# SESSION_DOMAIN=.fmmcbs.com
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
# SANCTUM_STATEFUL_DOMAINS=app.fmmcbs.com

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database
TRANSACTION_SYNC_ENABLED=true

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 Configuration
# Create an IAM user in AWS Console with S3 permissions
# Recommended user name: morata-fms-backend or morata-fms-production
# Generate access keys from IAM > Users > [username] > Security credentials > Create access key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
REVERB_APP_ID=morata-fms-local
REVERB_APP_KEY=morata-fms-local-key
REVERB_APP_SECRET=morata-fms-local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
SANCTUM_STATEFUL_DOMAINS=localhost:3000
