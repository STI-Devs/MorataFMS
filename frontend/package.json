      "esbuild"
    ],
    "overrides": {
      "ajv": "^6.14.0",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "brace-expansion@5": "5.0.5",
      "flatted": "^3.4.2",
      "minimatch@3": "3.1.4",
      "minimatch@9": "9.0.7",
      "picomatch": "^4.0.4",
      "rollup": "^4.59.0"
